{
  "name": "claudex-vscode",
  "displayName": "Claudex",
  "description": "Multi-provider VS Code companion for Claudex with project-aware launch behavior, provider switching, and a real Control Center.",
  "version": "0.2.0",
  "publisher": "devnull-bootloader",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Themes",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:claudex.start",
    "onCommand:claudex.startInWorkspaceRoot",
    "onCommand:claudex.openDocs",
    "onCommand:claudex.openSetupDocs",
    "onCommand:claudex.openWorkspaceProfile",
    "onCommand:claudex.openControlCenter",
    "onCommand:claudex.switchProvider",
    "onView:claudex.controlCenter"
  ],
  "main": "./src/extension.js",
  "files": [
    "README.md",
    "media/**",
    "src/extension.js",
    "src/presentation.js",
    "src/state.js",
    "themes/**"
  ],
  "contributes": {
    "commands": [
      {
        "command": "claudex.start",
        "title": "Claudex: Launch in Terminal",
        "category": "Claudex"
      },
      {
        "command": "claudex.startInWorkspaceRoot",
        "title": "Claudex: Launch in Workspace Root",
        "category": "Claudex"
      },
      {
        "command": "claudex.openDocs",
        "title": "Claudex: Open Repository",
        "category": "Claudex"
      },
      {
        "command": "claudex.openSetupDocs",
        "title": "Claudex: Open Setup Guide",
        "category": "Claudex"
      },
      {
        "command": "claudex.openWorkspaceProfile",
        "title": "Claudex: Open Workspace Profile",
        "category": "Claudex"
      },
      {
        "command": "claudex.openControlCenter",
        "title": "Claudex: Open Control Center",
        "category": "Claudex"
      },
      {
        "command": "claudex.switchProvider",
        "title": "Claudex: Switch Provider",
        "category": "Claudex"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "claudex",
          "title": "Claudex",
          "icon": "media/claudex.svg"
        }
      ]
    },
    "views": {
      "claudex": [
        {
          "id": "claudex.controlCenter",
          "name": "Control Center",
          "type": "webview"
        }
      ]
    },
    "configuration": {
      "title": "Claudex",
      "properties": {
        "claudex.launchCommand": {
          "type": "string",
          "default": "claudex",
          "description": "Command run in the integrated terminal when launching Claudex."
        },
        "claudex.terminalName": {
          "type": "string",
          "default": "Claudex",
          "description": "Integrated terminal tab name for Claudex sessions."
        },
        "claudex.activeProvider": {
          "type": "string",
          "default": "",
          "enum": ["", "anthropic", "openai", "gemini", "openrouter", "groq", "nim", "deepseek", "ollama"],
          "enumDescriptions": [
            "Auto-detect from environment",
            "Anthropic (first-party)",
            "OpenAI",
            "Google Gemini",
            "OpenRouter",
            "Groq",
            "NVIDIA NIM",
            "DeepSeek",
            "Ollama (local)"
          ],
          "description": "Active LLM provider. Sets CLAUDE_CODE_USE_<PROVIDER>=1 in launched terminals."
        }
      }
    },
    "themes": [
      {
        "label": "Claudex Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/claudex-dark.json"
      },
      {
        "label": "Claudex Light",
        "uiTheme": "vs",
        "path": "./themes/claudex-light.json"
      }
    ]
  },
  "scripts": {
    "test": "node --test ./src/*.test.js",
    "lint": "node -e \"for (const file of require('node:fs').readdirSync('./src')) { if (file.endsWith('.js')) { require('node:child_process').execFileSync(process.execPath, ['--check', require('node:path').join('src', file)], { stdio: 'inherit' }); } }\"",
    "package": "npx @vscode/vsce package --no-dependencies"
  },
  "keywords": [
    "claudex",
    "multi-provider",
    "terminal",
    "theme",
    "cli",
    "llm",
    "openai",
    "gemini",
    "ollama"
  ],
  "license": "MIT"
}
